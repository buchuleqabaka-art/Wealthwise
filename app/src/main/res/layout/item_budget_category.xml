<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#0A1628"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#1E3A6E"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Category name and amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Category icon + name container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- NEW: Category icon -->
                <ImageView
                    android:id="@+id/ivCategoryIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/category_icon_bg"
                    android:padding="6dp"
                    android:src="@drawable/ic_category_default"
                    android:contentDescription="Category icon" />

                <TextView
                    android:id="@+id/tvCategoryName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Category Name"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Amount with better styling -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 1,250"
                    android:textColor="#FF6B6B"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of R 2,500"
                    android:textColor="#B0C4DE"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Progress bar with better styling -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <ProgressBar
                android:id="@+id/progressCategory"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="#1E2D4A"
                android:progressTint="@color/progress_gradient"
                android:indeterminate="false" />

            <!-- NEW: Progress bar glow effect (optional) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/progress_glow"
                android:alpha="0.3" />

        </FrameLayout>

        <!-- Bottom row: Percentage + status + action icons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPercent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="50% used"
                android:textColor="#B0C4DE"
                android:textSize="12sp" />

            <!-- NEW: Status badge -->
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:background="@drawable/status_badge_bg"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="On Track"
                android:textColor="#00E5FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- NEW: Edit icon -->
            <ImageView
                android:id="@+id/ivEditCategory"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_edit"
                android:contentDescription="Edit category"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#6B8DB5" />

            <!-- NEW: Delete icon -->
            <ImageView
                android:id="@+id/ivDeleteCategory"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="Delete category"
                android:padding="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="#6B8DB5" />

        </LinearLayout>

        <!-- NEW: Progress alert for near limit -->
        <TextView
            android:id="@+id/tvLimitAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/alert_bg"
            android:gravity="center"
            android:padding="8dp"
            android:text="⚠️ 80% of budget used"
            android:textColor="#FFB347"
            android:textSize="11sp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>