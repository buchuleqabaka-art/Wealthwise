<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- ══ GLOBAL ACTIONS ══ -->
    <action
        android:id="@+id/action_global_addTransactionFragment"
        app:destination="@id/addTransactionFragment" />

    <action
        android:id="@+id/action_global_budgetFragment"
        app:destination="@id/budgetFragment" />

    <!-- ══ AUTH SCREENS ══ -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.wealthwise.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />

        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
            app:destination="@id/forgotPasswordFragment" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.example.wealthwise.ui.auth.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up">

        <!-- After creating account → go to Login to sign in -->
        <action
            android:id="@+id/action_signUpFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/signUpFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.wealthwise.ui.auth.ForgotPasswordFragment"
        android:label="Forgot Password"
        tools:layout="@layout/fragment_forgot_password">

        <action
            android:id="@+id/action_forgotPasswordFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.wealthwise.ui.auth.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_welcomeFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ══ MAIN APP SCREENS ══ -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.wealthwise.ui.dashboard.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_addTransactionFragment"
            app:destination="@id/addTransactionFragment" />
    </fragment>

    <fragment
        android:id="@+id/addTransactionFragment"
        android:name="com.example.wealthwise.ui.transactions.AddTransactionFragment"
        android:label="Add"
        tools:layout="@layout/fragment_add_transaction" />

    <fragment
        android:id="@+id/reportsFragment"
        android:name="com.example.wealthwise.ui.reports.ReportsFragment"
        android:label="Reports"
        tools:layout="@layout/fragment_reports" />

    <fragment
        android:id="@+id/budgetFragment"
        android:name="com.example.wealthwise.ui.budget.BudgetFragment"
        android:label="Budget"
        tools:layout="@layout/fragment_budget">

        <action
            android:id="@+id/action_budgetFragment_to_addCategoryFragment"
            app:destination="@id/addCategoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.wealthwise.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/addCategoryFragment"
        android:name="com.example.wealthwise.ui.budget.AddCategoryFragment"
        android:label="Add Category"
        tools:layout="@layout/fragment_add_category" />

    <fragment
        android:id="@+id/transactionListFragment"
        android:name="com.example.wealthwise.ui.transactions.TransactionListFragment"
        android:label="Transactions"
        tools:layout="@layout/fragment_transaction_list">

        <action
            android:id="@+id/action_transactionListFragment_to_addTransactionFragment"
            app:destination="@id/addTransactionFragment" />
    </fragment>

</navigation>